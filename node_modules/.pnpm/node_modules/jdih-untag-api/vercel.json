{
    "version": 2,
    "rewrites": [
        {
            "source": "/api/(.*)",
            "destination": "/src/api/src/server.js"
        },
        {
            "source": "/uploads/(.*)",
            "destination": "/src/api/src/server.js"
        },
        {
            "source": "/(.*)",
            "destination": "/src/frontend/dist/$1"
        }
    ]
}